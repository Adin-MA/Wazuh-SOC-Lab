<group name="authentication,bruteforce">

  <rule id="100100" level="13" frequency="7" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L1)</description>
  </rule>

  <rule id="100101" level="14" frequency="2" timeframe="3600">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L2)</description>
  </rule>

  <rule id="100102" level="15" frequency="2" timeframe="43200">
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected (L3)</description>
  </rule>
  
</group>

<group name="activity,root">
  
  <rule id="100200" level="12">
    <if_sid>5402</if_sid>
    <location>journald</location>
    <match>COMMAND=/usr/bin/(sh|bash)</match>
    <description>Suspicious Root Activity Detected</description>
  </rule>

</group>
